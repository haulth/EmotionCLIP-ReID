<mxfile host="app.diagrams.net" modified="2026-07-04T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="emotionclip_reid_w4_model_architecture" name="W4 Model Architecture">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2500" pageHeight="1350" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="&lt;b&gt;EmotionCLIP-ReID v1 Architecture - W4 Contributions&lt;/b&gt;&lt;br&gt;Marked blocks show what was newly added or modified in W4." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#FFFFFF;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=19;" vertex="1" parent="1"><mxGeometry x="70" y="30" width="1050" height="90" as="geometry"/></mxCell><mxCell id="legend_new" value="&lt;b&gt;NEW W4&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1370" y="50" width="150" height="42" as="geometry"/></mxCell><mxCell id="legend_mod" value="&lt;b&gt;MODIFIED&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1550" y="50" width="160" height="42" as="geometry"/></mxCell><mxCell id="legend_frozen" value="&lt;b&gt;REUSED/FROZEN&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E2E8F0;strokeColor=#64748B;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1750" y="50" width="210" height="42" as="geometry"/></mxCell><mxCell id="legend_metric" value="&lt;b&gt;OUTPUT/METRIC&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="1"><mxGeometry x="2000" y="50" width="205" height="42" as="geometry"/></mxCell><mxCell id="visual_band" value="&lt;b&gt;1. Visual feature branch&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F8FBFF;strokeColor=#CBD5E1;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=19;" vertex="1" parent="1"><mxGeometry x="60" y="160" width="2380" height="70" as="geometry"/></mxCell><mxCell id="semantic_band" value="&lt;b&gt;2. Semantic descriptor branch&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=19;" vertex="1" parent="1"><mxGeometry x="60" y="555" width="2380" height="70" as="geometry"/></mxCell><mxCell id="decision_band" value="&lt;b&gt;3. Decision, uncertainty and evaluation&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFF8ED;strokeColor=#FED7AA;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=19;" vertex="1" parent="1"><mxGeometry x="60" y="915" width="2380" height="70" as="geometry"/></mxCell><mxCell id="face" value="&lt;b&gt;Face image&lt;/b&gt;&lt;br&gt;Input x" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=15;" vertex="1" parent="1"><mxGeometry x="120" y="270" width="230" height="105" as="geometry"/></mxCell><mxCell id="prep" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;Face-safe preprocessing&lt;br&gt;Đã chuẩn hóa resize/align/light augmentation cho FER manifest." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="455" y="242" width="330" height="160" as="geometry"/></mxCell><mxCell id="vision" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;CLIP ViT-B/16 + expression adapters&lt;br&gt;Đã cài trainable residual adapters và fine-tune selected last blocks; CLIP backbone vẫn là nền tri thức." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="905" y="228" width="450" height="185" as="geometry"/></mxCell><mxCell id="visual_features" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;Visual features&lt;br&gt;Đã lấy global CLS token z_g và patch tokens P để dùng cho classifier/global-local alignment." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1505" y="242" width="390" height="160" as="geometry"/></mxCell><mxCell id="label" value="&lt;b&gt;Emotion labels&lt;/b&gt;&lt;br&gt;Input y: 7 basic emotions" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=15;" vertex="1" parent="1"><mxGeometry x="120" y="655" width="250" height="110" as="geometry"/></mxCell><mxCell id="prompt" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Learnable prompt&lt;br&gt;Đã thêm class-specific context tokens [X] cho từng cảm xúc." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="475" y="620" width="390" height="170" as="geometry"/></mxCell><mxCell id="text_encoder" value="&lt;b&gt;REUSED/FROZEN&lt;/b&gt;&lt;br&gt;Frozen CLIP text encoder&lt;br&gt;Dùng lại text transformer/projection của CLIP; không train ở Stage 2." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E2E8F0;strokeColor=#64748B;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="990" y="620" width="370" height="170" as="geometry"/></mxCell><mxCell id="desc" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Emotion descriptors T&lt;br&gt;Đã lưu fixed semantic anchors từ Stage 1 để neo visual features." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1505" y="620" width="390" height="170" as="geometry"/></mxCell><mxCell id="heads" value="&lt;b&gt;MODIFIED + NEW W4&lt;/b&gt;&lt;br&gt;Prediction heads&lt;br&gt;Classifier head đổi sang 7 lớp.&lt;br&gt;Global alignment: z_g T^T.&lt;br&gt;Local alignment: TopK(P T^T)." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ECFEFF;strokeColor=#0891B2;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="300" y="1015" width="430" height="165" as="geometry"/></mxCell><mxCell id="fusion" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;Fusion logits&lt;br&gt;Đã hợp nhất classifier + global + local: s = w_cls s_cls + w_g s_g + w_l s_l." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="870" y="1015" width="390" height="165" as="geometry"/></mxCell><mxCell id="evidential" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Evidential output&lt;br&gt;Đã xuất p(y|x) và uncertainty u(x) từ Dirichlet evidence." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1400" y="990" width="360" height="140" as="geometry"/></mxCell><mxCell id="objective" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;Training objective&lt;br&gt;Đã dùng L_cls + beta L_align + lambda L_unc trong Stage 2." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F8FAFC;strokeColor=#334155;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1400" y="1160" width="360" height="120" as="geometry"/></mxCell><mxCell id="metrics" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Evaluation metrics&lt;br&gt;Đã log macro-F1, balanced acc, per-class F1, ECE và uncertainty-risk AUC." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1900" y="1050" width="360" height="155" as="geometry"/></mxCell><mxCell id="note" value="&lt;b&gt;Ghi chú&lt;/b&gt;&lt;br&gt;NEW W4 = bổ sung mới; MODIFIED = chỉnh từ logic CLIP-ReID/W3 sang FER; REUSED/FROZEN = kế thừa CLIP." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="1"><mxGeometry x="90" y="1288" width="1200" height="48" as="geometry"/></mxCell><mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#334155;" edge="1" parent="1" source="face" target="prep"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#334155;" edge="1" parent="1" source="prep" target="vision"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#334155;" edge="1" parent="1" source="vision" target="visual_features"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#334155;" edge="1" parent="1" source="label" target="prompt"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#334155;" edge="1" parent="1" source="prompt" target="text_encoder"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#334155;" edge="1" parent="1" source="text_encoder" target="desc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" value="z_g, P" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0891B2;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#0891B2;" edge="1" parent="1" source="visual_features" target="heads"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e8" value="T" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0891B2;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#0891B2;" edge="1" parent="1" source="desc" target="heads"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0891B2;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#0891B2;" edge="1" parent="1" source="heads" target="fusion"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#DB2777;" edge="1" parent="1" source="fusion" target="evidential"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#334155;" edge="1" parent="1" source="fusion" target="objective"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#DB2777;" edge="1" parent="1" source="evidential" target="metrics"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontFamily=Arial;fontSize=13;fontColor=#334155;" edge="1" parent="1" source="objective" target="metrics"><mxGeometry relative="1" as="geometry"/></mxCell></root>
