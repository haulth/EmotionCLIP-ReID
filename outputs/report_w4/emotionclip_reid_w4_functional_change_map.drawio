<mxfile host="app.diagrams.net" modified="2026-07-03T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="emotionclip_reid_w4_functional_change_map" name="emotionclip_reid_w4_functional_change_map">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2100" pageHeight="1200" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="&lt;b&gt;Bản đồ khối chức năng W4: Bổ sung và Chỉnh sửa&lt;/b&gt;&lt;br&gt;Theo đóng góp nghiên cứu, không theo danh sách file code." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#FFFFFF;strokeWidth=2.2;fontSize=20;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="30" width="1100" height="80" as="geometry"/></mxCell><mxCell id="newh" value="&lt;b&gt;Khối bổ sung mới trong W4&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=2.2;fontSize=20;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="80" y="170" width="920" height="70" as="geometry"/></mxCell><mxCell id="modh" value="&lt;b&gt;Khối chỉnh sửa / mở rộng từ W3&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFBEB;strokeColor=#D97706;strokeWidth=2.2;fontSize=20;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1100" y="170" width="920" height="70" as="geometry"/></mxCell><mxCell id="new1" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;1. Dataset &amp; manifest&lt;br&gt;FER2013/HF + RAF-DB official split; outputs được tổng hợp tự động." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="270" width="810" height="93" as="geometry"/></mxCell><mxCell id="new2" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;2. Emotion descriptors&lt;br&gt;Prompt learner tạo class-specific semantic anchors cho 7 cảm xúc." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="383" width="810" height="93" as="geometry"/></mxCell><mxCell id="new3" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;3. Expression adapters&lt;br&gt;Adapter trong CLIP ViT và fine-tune selected last blocks." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="496" width="810" height="93" as="geometry"/></mxCell><mxCell id="new4" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;4. Global-local alignment&lt;br&gt;Kết hợp z_g T^T và Top-K patch-text alignment." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="609" width="810" height="93" as="geometry"/></mxCell><mxCell id="new5" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;5. Evidential uncertainty&lt;br&gt;Dirichlet evidence, ECE, uncertainty-risk AUC, avg_unc/avg_conf." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="722" width="810" height="93" as="geometry"/></mxCell><mxCell id="new6" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;6. Evidence artifacts&lt;br&gt;SOTA benchmark, training curves, AU Stage 2 result, per-class F1." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="835" width="810" height="93" as="geometry"/></mxCell><mxCell id="mod1" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;1. ReID objective -&gt; FER objective&lt;br&gt;Từ ID classification/triplet sang 7-class facial expression recognition." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1145" y="270" width="810" height="93" as="geometry"/></mxCell><mxCell id="mod2" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;2. Two-stage protocol&lt;br&gt;Giữ scaffold CLIP-ReID nhưng tách rõ frozen/trainable cho FER." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1145" y="383" width="810" height="93" as="geometry"/></mxCell><mxCell id="mod3" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;3. Loss design&lt;br&gt;CE đơn -&gt; CE classification + beta alignment + lambda uncertainty." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1145" y="496" width="810" height="93" as="geometry"/></mxCell><mxCell id="mod4" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;4. Evaluation protocol&lt;br&gt;Accuracy-only -&gt; macro-F1, balanced acc, per-class F1, ECE/risk AUC." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1145" y="609" width="810" height="93" as="geometry"/></mxCell><mxCell id="mod5" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;5. Checkpoint selection&lt;br&gt;Chọn theo macro-F1 thay vì loss cuối hoặc accuracy đơn thuần." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1145" y="722" width="810" height="93" as="geometry"/></mxCell><mxCell id="mod6" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;6. Report style&lt;br&gt;Từ liệt kê file code sang khối chức năng có luận điểm học thuật." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#D97706;strokeWidth=2.2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1145" y="835" width="810" height="93" as="geometry"/></mxCell><mxCell id="evidence" value="&lt;b&gt;Bằng chứng đã bổ sung vào báo cáo&lt;/b&gt;&lt;br&gt;SOTA benchmark, outputs table, validation/training curves, per-class F1, two-stage detail, uncertainty detail, AU Stage 2 result." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=2.2;fontSize=16;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="250" y="1040" width="1600" height="105" as="geometry"/></mxCell></root>
    </mxGraphModel>
  </diagram>
