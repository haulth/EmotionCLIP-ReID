<mxfile host="app.diagrams.net" modified="2026-05-12T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="emotionclip-related-work-gap-map" name="Related Work Gap Map">
    <mxGraphModel dx="1480" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="860" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Related Work Reasoning Map&lt;br&gt;Core thesis: replace ID-specific tokens with emotion/AU semantic anchors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2F8;strokeColor=#1F4E78;strokeWidth=2;arcSize=8;fontSize=19;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="285" y="20" width="700" height="75" as="geometry"/></mxCell><mxCell id="foundation" value="VLM Adaptation (2022+)&lt;br&gt;Tip-Adapter, CoOp, CoCoOp, MaPLe&lt;br&gt;Strong: prompt/adapter learning&lt;br&gt;Risk: class-name prompt is too coarse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2F8;strokeColor=#1F4E78;strokeWidth=2;arcSize=8;fontSize=14;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="40" y="140" width="260" height="145" as="geometry"/></mxCell><mxCell id="reid" value="Language-Guided ReID&lt;br&gt;CLIP-ReID, Pedestrian Prompt, CLIP-SCGI, CSDN&lt;br&gt;Keep: 2-stage text-anchor training&lt;br&gt;Change: ID token -&gt; emotion/AU descriptor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2F0D9;strokeColor=#548235;strokeWidth=2;arcSize=8;fontSize=14;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="350" y="140" width="280" height="145" as="geometry"/></mxCell><mxCell id="emotion" value="CLIP-based FER/DFER&lt;br&gt;CLIPER, DFER-CLIP, FineCLIPER, EA-CLIP&lt;br&gt;Risk: adapter-only contribution is weak&lt;br&gt;Need: descriptor pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#C65911;strokeWidth=2;arcSize=8;fontSize=14;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="700" y="140" width="300" height="145" as="geometry"/></mxCell><mxCell id="au" value="AU/FACS Semantics&lt;br&gt;MER-CLIP, VL-FAU, AUFormer, Norface, AUNCE&lt;br&gt;Strong: interpretable muscle cues&lt;br&gt;Gap: AU labels are missing/noisy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4D6;strokeColor=#C00000;strokeWidth=2;arcSize=8;fontSize=14;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="1060" y="140" width="300" height="145" as="geometry"/></mxCell><mxCell id="unc" value="Uncertainty FER (2022+)&lt;br&gt;MTAC, MAN, LDL, ULC-AG, UA-FER, 3WAUS&lt;br&gt;Use as calibration after baseline&lt;br&gt;Do not let it become the main thesis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4CCCC;strokeColor=#A61C00;strokeWidth=2;arcSize=8;fontSize=14;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="180" y="380" width="310" height="145" as="geometry"/></mxCell><mxCell id="multi" value="Multimodal MER (2022+)&lt;br&gt;Dirichlet MER, COLD Fusion, HUC, DMD, M2FNet&lt;br&gt;Borrow reliability/fusion ideas&lt;br&gt;V1 remains image-text" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#674EA7;strokeWidth=2;arcSize=8;fontSize=14;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="560" y="380" width="340" height="145" as="geometry"/></mxCell><mxCell id="gap" value="Research Gap&lt;br&gt;No compact framework yet converts CLIP-ReID&#x27;s ID-token learning into emotion/AU descriptor anchors for FER.&lt;br&gt;Need interpretability + robustness without over-scoping." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#334155;strokeWidth=2;arcSize=8;fontSize=15;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="960" y="380" width="340" height="145" as="geometry"/></mxCell><mxCell id="project" value="Current Project: EmotionCLIP-ReID&lt;br&gt;Stage 1: learn emotion/AU descriptors&lt;br&gt;Stage 2: freeze anchors and guide image encoder/adapters&lt;br&gt;Auxiliary: local alignment + uncertainty ablations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D9EAD3;strokeColor=#38761D;strokeWidth=2;arcSize=8;fontSize=17;fontFamily=Arial;fontColor=#111827;" vertex="1" parent="1"><mxGeometry x="345" y="640" width="690" height="145" as="geometry"/></mxCell><mxCell id="e1" value="prompt learning" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="foundation" target="reid"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="replace ID tokens" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="reid" target="emotion"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="fine-grained semantics" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="emotion" target="au"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="interpretability gap" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="au" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="ambiguity" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="unc" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" value="robustness" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="multi" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" value="proposed answer" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="gap" target="project"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e8" value="adapters + descriptors" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="emotion" target="project"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e9" value="calibration" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="unc" target="project"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e10" value="future extension" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#475569;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontFamily=Arial;" edge="1" parent="1" source="multi" target="project"><mxGeometry relative="1" as="geometry"/></mxCell>
