    <diagram id="emotionclip-anatomy-gap-map" name="Research Gap to Implementation">
        <mxGraphModel dx="2200" dy="1350" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3700" pageHeight="2400" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;b&gt;EmotionCLIP-ReID Research Gap Map&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#0F2742;fontSize=38;align=left;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="70" y="28" width="2200" height="52" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Từ bằng chứng hiện tại → khoảng trống khoa học → anatomy-conditioned prompting → reliability-aware patch routing → kiểm chứng và triển khai" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#475569;fontSize=20;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="75" y="82" width="2600" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="L_GAP" value="&lt;b&gt;GAP / RISK&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#B42318;strokeColor=#B42318;strokeWidth=2.6;fontFamily=Arial;fontColor=#FFFFFF;fontSize=12;spacing=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="2660" y="42" width="180" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="L_DEC" value="&lt;b&gt;RESEARCH DECISION&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#6D28D9;strokeColor=#6D28D9;strokeWidth=2.6;fontFamily=Arial;fontColor=#FFFFFF;fontSize=12;spacing=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="2852" y="42" width="180" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="L_IMPL" value="&lt;b&gt;PROPOSED MODULE&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#2563EB;strokeColor=#2563EB;strokeWidth=2.6;fontFamily=Arial;fontColor=#FFFFFF;fontSize=12;spacing=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="3044" y="42" width="180" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="L_MET" value="&lt;b&gt;LOSS / METRIC&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DB2777;strokeColor=#DB2777;strokeWidth=2.6;fontFamily=Arial;fontColor=#FFFFFF;fontSize=12;spacing=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="3236" y="42" width="180" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="L_GATE" value="&lt;b&gt;GO / NO-GO&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#00827C;strokeColor=#00827C;strokeWidth=2.6;fontFamily=Arial;fontColor=#FFFFFF;fontSize=12;spacing=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
                    <mxGeometry x="3428" y="42" width="180" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="gap_panel" value="&lt;b&gt;1. Bằng chứng hiện tại &amp;amp; research gaps&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:18px;color:#475569'&gt;Những vấn đề phải giải quyết trước khi claim novelty/generalization&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B42318;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=27;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1">
                    <mxGeometry x="70" y="150" width="790" height="1690" as="geometry"/>
                </mxCell>
                <mxCell id="decision_panel" value="&lt;b&gt;2. Research decision&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:18px;color:#475569'&gt;Đổi câu hỏi từ “landmark có tăng accuracy?” sang phân biệt ambiguity thật và unreliability&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FCFAFF;strokeColor=#6D28D9;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=27;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1">
                    <mxGeometry x="910" y="150" width="710" height="1690" as="geometry"/>
                </mxCell>
                <mxCell id="stage1_panel" value="&lt;b&gt;3. Stage 1 — Anatomy-conditioned prompting&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:18px;color:#475569'&gt;Class-level robust geometry → role-structured prompt tokens → fixed semantic anchors&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FFFDF7;strokeColor=#D97706;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=27;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1">
                    <mxGeometry x="1670" y="150" width="940" height="1000" as="geometry"/>
                </mxCell>
                <mxCell id="stage2_panel" value="&lt;b&gt;4. Stage 2 — Reliability-aware anatomical routing&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:18px;color:#475569'&gt;Instance landmarks guide CLIP patches; quality controls how strongly anatomy is trusted&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#F8FBFF;strokeColor=#2563EB;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=27;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1">
                    <mxGeometry x="2660" y="150" width="970" height="1000" as="geometry"/>
                </mxCell>
                <mxCell id="outputs_panel" value="&lt;b&gt;5. Outputs &amp;amp; uncertainty decomposition&lt;/b&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FFF9FC;strokeColor=#DB2777;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=27;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1">
                    <mxGeometry x="1670" y="1200" width="940" height="640" as="geometry"/>
                </mxCell>
                <mxCell id="eval_panel" value="&lt;b&gt;6. Validation, ablation &amp;amp; publication evidence&lt;/b&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#F7FFFD;strokeColor=#00827C;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=27;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1">
                    <mxGeometry x="2660" y="1200" width="970" height="640" as="geometry"/>
                </mxCell>
                <mxCell id="roadmap_panel" value="&lt;b&gt;7. Triển khai theo causal ladder&lt;/b&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#0F2742;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=27;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1">
                    <mxGeometry x="70" y="1900" width="3560" height="410" as="geometry"/>
                </mxCell>
                <mxCell id="g_protocol" value="&lt;b&gt;G0 — Protocol &amp;amp; provenance&lt;/b&gt;&lt;br&gt;Split đã được sửa, nhưng metric cũ phải rerun.&lt;br&gt;Run cần Git/config/manifest hash, immutable run_id, 3–5 seeds." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="115" y="270" width="700" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="g_novelty" value="&lt;b&gt;G1 — Novelty collision&lt;/b&gt;&lt;br&gt;Two-stage prompt, adapter, global/local alignment và landmark regions đều đã có tiền lệ.&lt;br&gt;&lt;b&gt;Không claim “chia vùng mặt” là mới.&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="115" y="485" width="700" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="g_unc" value="&lt;b&gt;G2 — Uncertainty không identifiable&lt;/b&gt;&lt;br&gt;softplus(fused logits) đổi theo common-logit offset dù softmax không đổi.&lt;br&gt;Cần probability và evidence strength tách biệt." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="115" y="700" width="700" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="g_fusion" value="&lt;b&gt;G3 — Fusion scale không kiểm soát&lt;/b&gt;&lt;br&gt;Classifier/global/local khác scale; raw weights có thể âm.&lt;br&gt;Cần branch temperature + simplex gate + telemetry." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="115" y="915" width="700" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="g_petl" value="&lt;b&gt;G4 — Baseline chưa phải adapter-only PETL&lt;/b&gt;&lt;br&gt;Stage 2 unfreeze last blocks.&lt;br&gt;Baseline chính: original CLIP frozen, last_blocks=0; ablate 0/1/2." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="115" y="1130" width="700" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="g_local" value="&lt;b&gt;G5 — Local Top-K thiếu anatomy &amp;amp; faithfulness&lt;/b&gt;&lt;br&gt;Hard Top-K có thể chọn tóc/nền và nhạy biên patch.&lt;br&gt;Heatmap đơn thuần chưa chứng minh causal explanation." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="115" y="1345" width="700" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="g_geometry" value="&lt;b&gt;G6 — Geometry chưa đi vào semantic stage&lt;/b&gt;&lt;br&gt;Prompt hiện chỉ có 4 latent [X] tokens; chưa biết upper/middle/lower-face geometry, asymmetry hay class variation." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="115" y="1560" width="700" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="rq" value="&lt;b&gt;RESEARCH QUESTION&lt;/b&gt;&lt;br&gt;&lt;br&gt;Có thể dùng cấu trúc hình học khuôn mặt để:&lt;br&gt;&lt;b&gt;(1)&lt;/b&gt; cập nhật emotion semantics ở Stage 1,&lt;br&gt;&lt;b&gt;(2)&lt;/b&gt; điều hướng visual evidence ở Stage 2,&lt;br&gt;và &lt;b&gt;(3)&lt;/b&gt; phân biệt bất đồng cảm xúc có ý nghĩa giữa các vùng đáng tin với bất đồng giả do landmark/ảnh bị lỗi hay không?" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#6D28D9;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="955" y="275" width="620" height="255" as="geometry"/>
                </mxCell>
                <mxCell id="novelty_no" value="&lt;b&gt;Không phải novelty&lt;/b&gt;&lt;br&gt;• crop mắt–mũi–miệng&lt;br&gt;• landmark region tokens&lt;br&gt;• face parsing + ViT&lt;br&gt;• local attention thông thường" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="955" y="585" width="285" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="novelty_yes" value="&lt;b&gt;Khoảng trống khả thi&lt;/b&gt;&lt;br&gt;• geometry-to-prompt-to-patch nhất quán&lt;br&gt;• soft routing chịu landmark jitter&lt;br&gt;• quality-aware hybrid anatomy/free attention&lt;br&gt;• conditional regional disagreement" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="1280" y="585" width="295" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="geometry_contract" value="&lt;b&gt;Shared anatomy representation g(x)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Eye-aligned coordinates; scale bởi inter-ocular distance.&lt;br&gt;6 vùng: brow · eyes · cheeks · nose · mouth · jaw.&lt;br&gt;Robust median/MAD + visibility + detector stability.&lt;br&gt;&lt;br&gt;&lt;b&gt;Rule:&lt;/b&gt; pose/blur/confidence chỉ làm quality gate; không được encode thành emotion semantics." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=18;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="955" y="900" width="620" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="related_work" value="&lt;b&gt;Comparator bắt buộc&lt;/b&gt;&lt;br&gt;CLIP-ReID (two-stage anchors) · CEPrompt/MPA-FER (prompt + local alignment) · FineCLIPER (landmark/parsing + CLIP) · LA-Net (landmark-aware FER) · Face-LLaVA (region landmark tokens + cross-attention).&lt;br&gt;&lt;br&gt;&lt;b&gt;Claim phải vượt khỏi:&lt;/b&gt; “landmark giúp FER accuracy”." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=left;verticalAlign=middle;dashed=1;dashPattern=8 6;" vertex="1" parent="1">
                    <mxGeometry x="955" y="1260" width="620" height="305" as="geometry"/>
                </mxCell>
                <mxCell id="claim" value="&lt;b&gt;Proposed claim&lt;/b&gt;&lt;br&gt;Robust facial geometry conditions class prompts and provides quality-aware priors for visual patch routing; only disagreement among reliable regions is interpreted as intrinsic ambiguity." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=18;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="955" y="1620" width="620" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="s1_train" value="&lt;b&gt;Train split only&lt;/b&gt;&lt;br&gt;landmarks + emotion labels" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="1720" y="275" width="210" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="s1_stats" value="&lt;b&gt;Robust class geometry&lt;/b&gt;&lt;br&gt;μ&lt;sub&gt;y,r&lt;/sub&gt; = median(g&lt;sub&gt;r&lt;/sub&gt;|y)&lt;br&gt;s&lt;sub&gt;y,r&lt;/sub&gt; = MAD/IQR&lt;br&gt;q&lt;sub&gt;y,r&lt;/sub&gt; = valid/stable rate" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="1970" y="250" width="270" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="s1_prompt_structure" value="&lt;b&gt;Role-structured prompt&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:15px'&gt;“A photo of a face with&lt;br&gt;[GLOBAL] [UPPER] [MIDDLE] [LOWER]&lt;br&gt;[ASYMMETRY] [VARIATION]&lt;br&gt;showing a {emotion} expression.”&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=17;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="2280" y="230" width="285" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="s1_vars" value="&lt;b&gt;Prompt variables&lt;/b&gt;&lt;br&gt;UPPER: brow–eye distance, EAR, slope&lt;br&gt;MIDDLE: cheek geometry, nose anchor&lt;br&gt;LOWER: MAR, mouth corners, jaw opening&lt;br&gt;ASYM: left–right differences&lt;br&gt;VAR: class dispersion/quantiles" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#D97706;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="1720" y="465" width="395" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="s1_equation" value="&lt;b&gt;Anatomy residual&lt;/b&gt;&lt;br&gt;C*&lt;sub&gt;y,r&lt;/sub&gt; = C&lt;sup&gt;base&lt;/sup&gt;&lt;sub&gt;y,r&lt;/sub&gt; + γ&lt;sub&gt;r&lt;/sub&gt; q&lt;sub&gt;y,r&lt;/sub&gt; tanh(P&lt;sub&gt;r&lt;/sub&gt;[μ&lt;sub&gt;y,r&lt;/sub&gt;, log s&lt;sub&gt;y,r&lt;/sub&gt;])&lt;br&gt;&lt;br&gt;Projector zero-init; γ starts near 0.&lt;br&gt;Numeric coordinates are &lt;b&gt;not&lt;/b&gt; converted to text." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#6D28D9;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=left;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="2160" y="465" width="405" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="s1_text_encoder" value="&lt;b&gt;Frozen CLIP text encoder&lt;/b&gt;&lt;br&gt;one conditioned descriptor per class" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="1720" y="770" width="260" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s1_loss" value="&lt;b&gt;Stage 1 objective&lt;/b&gt;&lt;br&gt;L&lt;sub&gt;1&lt;/sub&gt; = CE(image·text, y)&lt;br&gt;+ prompt-shift regularization&lt;br&gt;+ semantic retention" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="2020" y="750" width="265" height="135" as="geometry"/>
                </mxCell>
                <mxCell id="s1_anchors" value="&lt;b&gt;Fixed anchors T*&lt;/b&gt;&lt;br&gt;7 class descriptors&lt;br&gt;reused by Stage 2" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="2325" y="770" width="240" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="s1_guard" value="&lt;b&gt;Leakage guard&lt;/b&gt;&lt;br&gt;Fit median/MAD/quantiles trên train only; lưu landmark model, feature schema và manifest hash." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=left;verticalAlign=middle;dashed=1;dashPattern=8 6;" vertex="1" parent="1">
                    <mxGeometry x="1720" y="950" width="845" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="s2_input" value="&lt;b&gt;Face image x&lt;/b&gt;&lt;br&gt;transform-aware landmarks" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="2710" y="270" width="205" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="s2_clip" value="&lt;b&gt;Frozen CLIP ViT&lt;/b&gt;&lt;br&gt;global h&lt;sub&gt;g&lt;/sub&gt; + patch tokens v&lt;sub&gt;p&lt;/sub&gt;&lt;br&gt;&lt;font style='font-size:14px'&gt;baseline last_blocks=0&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="2960" y="245" width="250" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="s2_quality" value="&lt;b&gt;Region quality q&lt;sub&gt;r&lt;/sub&gt;&lt;/b&gt;&lt;br&gt;confidence · visibility · pose&lt;br&gt;augmentation stability · occlusion&lt;br&gt;outside-crop fraction" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
                    <mxGeometry x="3250" y="245" width="325" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="s2_anat" value="&lt;b&gt;Soft anatomical prior&lt;/b&gt;&lt;br&gt;M&lt;sup&gt;anat&lt;/sup&gt;&lt;sub&gt;pr&lt;/sub&gt; ∝ exp[-d(p,R&lt;sub&gt;r&lt;/sub&gt;)²/σ²&lt;sub&gt;r&lt;/sub&gt;]&lt;br&gt;soft membership; 0.5–1.5 patch σ ablation" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.6;fontFamily=Arial;fontColor=#111827;fontSize=16;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
