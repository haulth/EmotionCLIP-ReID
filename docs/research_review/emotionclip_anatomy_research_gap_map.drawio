<mxfile host="65bd71144e">
    <diagram id="emotionclip-final-plan" name="Final Plan Before to After">
        <mxGraphModel dx="1026" dy="1002" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3300" pageHeight="2520" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;b&gt;EmotionCLIP-ReID — Kế hoạch phát triển mô hình phiên bản chốt&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#0F2742;fontSize=19;align=left;verticalAlign=middle;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="25" width="2500" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Bốn thay đổi có thể kiểm chứng độc lập: data contract → Stage 2 dual stream → Stage 1 geometry prompt → uncertainty/ambiguity outputs" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#475569;fontSize=19;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="75" y="82" width="2700" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="rq" value="&lt;b&gt;CÂU HỎI NGHIÊN CỨU&lt;/b&gt;&lt;br&gt;Liệu phân bố hình học cấp lớp có thể cải thiện emotion prompts ở Stage 1, và hình học cấp ảnh có thể hướng dẫn CLIP patch routing ở Stage 2, trong khi mô hình tự bỏ qua landmark không đáng tin do pose, crop, occlusion hoặc detector failure?&lt;br&gt;&lt;br&gt;&lt;b&gt;Nguyên tắc:&lt;/b&gt; landmark vừa là spatial prior, vừa là geometry feature; cả hai chỉ được sử dụng theo reliability từng vùng và luôn có visual-only fallback." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#6D28D9;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="75" y="140" width="3150" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="foundation" value="&lt;b&gt;FOUNDATION GIỮ CỐ ĐỊNH KHI ABLATE&lt;/b&gt; &amp;nbsp; sealed train/val/test · immutable run/provenance · original CLIP frozen (last_blocks=0 baseline) · branch temperature + simplex fusion · decoupled probability/strength" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;dashed=1;dashPattern=8 6;" parent="1" vertex="1">
                    <mxGeometry x="75" y="315" width="3150" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="h_scope" value="&lt;b&gt;KHỐI CẦN SỬA&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#0F2742;fontSize=19;align=center;verticalAlign=middle;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="85" y="415" width="300" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="h_before" value="&lt;b&gt;TỪ — HIỆN TẠI&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#B42318;fontSize=19;align=center;verticalAlign=middle;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="440" y="415" width="700" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="h_after" value="&lt;b&gt;SANG — PHIÊN BẢN CHỐT&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#15803D;fontSize=19;align=center;verticalAlign=middle;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1215" y="415" width="1120" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="h_test" value="&lt;b&gt;GIỮ LẠI KHI&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#00827C;fontSize=19;align=center;verticalAlign=middle;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="2410" y="415" width="720" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="geometry_scope" value="&lt;font&gt;&lt;b&gt;01&lt;/b&gt;&lt;/font&gt;&lt;br&gt;DATA CONTRACT&lt;br&gt;&lt;b&gt;SHARED GEOMETRY&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="85" y="480" width="300" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="geometry_before" value="&lt;b&gt;Không có geometry artifact chuẩn&lt;/b&gt;&lt;br&gt;Batch chỉ mang image/label; raw coordinates dễ bị dùng sai.&lt;br&gt;&lt;br&gt;Missing landmark có nguy cơ bị điền tọa độ giả; flip/crop không bảo đảm đồng bộ landmark; chưa đo detector jitter hay signal-to-jitter." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="440" y="480" width="700" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="geometry_after" value="&lt;b&gt;Một representation dùng chung cho hai stage&lt;/b&gt;&lt;br&gt;g(x) = [g&lt;sub&gt;upper&lt;/sub&gt;, g&lt;sub&gt;middle&lt;/sub&gt;, g&lt;sub&gt;lower&lt;/sub&gt;]&lt;br&gt;&lt;br&gt;UPPER: brow + left/right eyes · MIDDLE: nose + cheeks · LOWER: mouth + chin/jaw.&lt;br&gt;Mỗi điểm: l&lt;sub&gt;i&lt;/sub&gt;=(x&lt;sub&gt;i&lt;/sub&gt;,y&lt;sub&gt;i&lt;/sub&gt;,v&lt;sub&gt;i&lt;/sub&gt;,c&lt;sub&gt;i&lt;/sub&gt;,u&lt;sub&gt;i&lt;/sub&gt;). Mỗi feature: value + valid mask + uncertainty.&lt;br&gt;Encoder nhận [g&lt;sub&gt;r&lt;/sub&gt;⊙m&lt;sub&gt;r&lt;/sub&gt;, m&lt;sub&gt;r&lt;/sub&gt;, u&lt;sub&gt;r&lt;/sub&gt;]. Không mirror/fill điểm giả; transform-aware artifact; ưu tiên 3D mesh khi pose lớn." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1215" y="480" width="1120" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="geometry_test" value="&lt;b&gt;Geometry audit trên RAF-DB&lt;/b&gt;&lt;br&gt;• detection/missing rate&lt;br&gt;• pose distribution&lt;br&gt;• augmentation jitter&lt;br&gt;• signal-to-jitter từng feature&lt;br&gt;• visible-side behavior&lt;br&gt;&lt;br&gt;q&lt;sub&gt;r&lt;/sub&gt;=0 phải tắt anatomy sạch sẽ.&lt;br&gt;&lt;font color=&quot;#6D28D9&quot;&gt;&lt;b&gt;Đối chiếu [R4–R7]&lt;/b&gt;&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="2410" y="480" width="720" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="geometry_delta" value="SỬA" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00827C;strokeWidth=2.8;endArrow=block;endFill=1;fontFamily=Arial;fontSize=19;fontColor=#111827;labelBackgroundColor=#FFFFFF;" parent="1" source="geometry_before" target="geometry_after" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="geometry_evidence" value="KIỂM CHỨNG" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00827C;strokeWidth=2.8;endArrow=block;endFill=1;fontFamily=Arial;fontSize=19;fontColor=#111827;labelBackgroundColor=#FFFFFF;" parent="1" source="geometry_after" target="geometry_test" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="stage2_scope" value="&lt;font&gt;&lt;b&gt;02&lt;/b&gt;&lt;/font&gt;&lt;br&gt;STAGE 2&lt;br&gt;&lt;b&gt;DUAL STREAM&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="85" y="800" width="300" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="stage2_before" value="&lt;b&gt;Một local stream dùng hard Top-K&lt;/b&gt;&lt;br&gt;Patch chọn thuần theo image–text similarity; không biết vùng, visibility hoặc landmark quality.&lt;br&gt;&lt;br&gt;Không có geometry feature mô tả “vùng đó biến dạng thế nào”; landmark failure có thể trở thành single point of failure." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="440" y="800" width="700" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="stage2_after" value="&lt;b&gt;Visual-primary + reliability-gated geometry residual&lt;/b&gt;&lt;br&gt;&lt;b&gt;Visual stream:&lt;/b&gt; A&lt;sub&gt;r,p&lt;/sub&gt; từ observed landmarks với w&lt;sub&gt;i&lt;/sub&gt;=v&lt;sub&gt;i&lt;/sub&gt;c&lt;sub&gt;i&lt;/sub&gt;exp(−u&lt;sub&gt;i&lt;/sub&gt;/τ); F&lt;sub&gt;r,p&lt;/sub&gt; là free attention; M*&lt;sub&gt;r,p&lt;/sub&gt;=q&lt;sub&gt;r&lt;/sub&gt;A&lt;sub&gt;r,p&lt;/sub&gt;+(1−q&lt;sub&gt;r&lt;/sub&gt;)F&lt;sub&gt;r,p&lt;/sub&gt;.&lt;br&gt;&lt;b&gt;Geometry stream:&lt;/b&gt; h&lt;sup&gt;geom&lt;/sup&gt;&lt;sub&gt;r&lt;/sub&gt;=G&lt;sub&gt;r&lt;/sub&gt;([g&lt;sub&gt;r&lt;/sub&gt;⊙m&lt;sub&gt;r&lt;/sub&gt;,m&lt;sub&gt;r&lt;/sub&gt;,u&lt;sub&gt;r&lt;/sub&gt;]).&lt;br&gt;&lt;b&gt;Gated residual:&lt;/b&gt; h&lt;sub&gt;r&lt;/sub&gt;=LN[h&lt;sup&gt;vis&lt;/sup&gt;&lt;sub&gt;r&lt;/sub&gt;+γ&lt;sub&gt;r&lt;/sub&gt;q&lt;sub&gt;r&lt;/sub&gt;tanh(h&lt;sup&gt;geom&lt;/sup&gt;&lt;sub&gt;r&lt;/sub&gt;)].&lt;br&gt;q&lt;sub&gt;r&lt;/sub&gt;=0 ⇒ content-only free attention; geometry projector zero-init." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1215" y="800" width="1120" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="stage2_test" value="&lt;b&gt;S0→S6 và SF&lt;/b&gt;&lt;br&gt;S2→S3: fallback có ích?&lt;br&gt;S3→S4: geometry thêm gì ngoài localization?&lt;br&gt;SF→S5: reliability gate có hơn landmark injection luôn bật?&lt;br&gt;&lt;br&gt;Giữ khi tốt hơn trên pose/blur/occlusion, worst-class F1 và deletion/insertion.&lt;br&gt;&lt;font color=&quot;#6D28D9&quot;&gt;&lt;b&gt;Đối chiếu [R3–R7]&lt;/b&gt;&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="2410" y="800" width="720" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="stage2_delta" value="SỬA" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2.8;endArrow=block;endFill=1;fontFamily=Arial;fontSize=19;fontColor=#111827;labelBackgroundColor=#FFFFFF;" parent="1" source="stage2_before" target="stage2_after" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="stage2_evidence" value="KIỂM CHỨNG" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00827C;strokeWidth=2.8;endArrow=block;endFill=1;fontFamily=Arial;fontSize=19;fontColor=#111827;labelBackgroundColor=#FFFFFF;" parent="1" source="stage2_after" target="stage2_test" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="stage1_scope" value="&lt;font&gt;&lt;b&gt;03&lt;/b&gt;&lt;/font&gt;&lt;br&gt;STAGE 1&lt;br&gt;&lt;b&gt;CLASS PROMPT&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="85" y="1170" width="300" height="290" as="geometry"/>
                </mxCell>
                <mxCell id="stage1_before" value="&lt;b&gt;Class-only prompt học trong một bước&lt;/b&gt;&lt;br&gt;“A photo of a face showing [X1][X2][X3][X4] expression of {emotion}.”&lt;br&gt;&lt;br&gt;Base context có thể hấp thụ mọi tín hiệu, nên khó xác định geometry residual thực sự đóng góp hay chỉ thêm parameters." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="440" y="1170" width="700" height="290" as="geometry"/>
                </mxCell>
                <mxCell id="stage1_after" value="&lt;b&gt;4 role tokens + training 1A/1B&lt;/b&gt;&lt;br&gt;“A photo of a face with [GLOBAL] [UPPER] [MIDDLE] [LOWER] showing a {emotion} expression.”&lt;br&gt;&lt;br&gt;μ&lt;sub&gt;y,r&lt;/sub&gt;=median(g&lt;sub&gt;r&lt;/sub&gt;|y); s&lt;sub&gt;y,r&lt;/sub&gt;=1.4826 MAD(g&lt;sub&gt;r&lt;/sub&gt;|y), fit train only.&lt;br&gt;C*&lt;sub&gt;y,r&lt;/sub&gt;=C&lt;sup&gt;base&lt;/sup&gt;&lt;sub&gt;y,r&lt;/sub&gt;+γ&lt;sub&gt;r&lt;/sub&gt;q&lt;sub&gt;y,r&lt;/sub&gt;tanh P&lt;sub&gt;r&lt;/sub&gt;([μ&lt;sub&gt;y,r&lt;/sub&gt;,log(s&lt;sub&gt;y,r&lt;/sub&gt;+ε)]).&lt;br&gt;&lt;b&gt;1A:&lt;/b&gt; học base prompt. &lt;b&gt;1B:&lt;/b&gt; freeze base, chỉ học projector/gate. Output vẫn là một fixed text descriptor/class." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1215" y="1170" width="1120" height="290" as="geometry"/>
                </mxCell>
                <mxCell id="stage1_test" value="&lt;b&gt;P0→P4 + PR/PS&lt;/b&gt;&lt;br&gt;P1 role tokens&lt;br&gt;P2 + median&lt;br&gt;P3 + MAD&lt;br&gt;P4 + quality gate&lt;br&gt;PR random geometry&lt;br&gt;PS shuffled class geometry&lt;br&gt;&lt;br&gt;Chỉ triển khai sau khi S3/S4 chứng minh geometry hữu ích.&lt;br&gt;&lt;font color=&quot;#6D28D9&quot;&gt;&lt;b&gt;Đối chiếu [R1–R4]&lt;/b&gt;&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="2410" y="1170" width="720" height="290" as="geometry"/>
                </mxCell>
                <mxCell id="stage1_delta" value="SỬA" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D97706;strokeWidth=2.8;endArrow=block;endFill=1;fontFamily=Arial;fontSize=19;fontColor=#111827;labelBackgroundColor=#FFFFFF;" parent="1" source="stage1_before" target="stage1_after" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="stage1_evidence" value="KIỂM CHỨNG" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00827C;strokeWidth=2.8;endArrow=block;endFill=1;fontFamily=Arial;fontSize=19;fontColor=#111827;labelBackgroundColor=#FFFFFF;" parent="1" source="stage1_after" target="stage1_test" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outputs_scope" value="&lt;font&gt;&lt;b&gt;04&lt;/b&gt;&lt;/font&gt;&lt;br&gt;OUTPUT + LOSS&lt;br&gt;&lt;b&gt;RELIABILITY&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="85" y="1500" width="300" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="outputs_before" value="&lt;b&gt;Một uncertainty scalar&lt;/b&gt;&lt;br&gt;EDL cũ suy evidence từ fused-logit scale/offset và không phân biệt class confusion, regional disagreement và input corruption.&lt;br&gt;&lt;br&gt;Raw region disagreement có thể tăng giả khi landmark thiếu hoặc ảnh bị che." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="440" y="1500" width="700" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="outputs_after" value="&lt;b&gt;Ba output tách biệt + validity&lt;/b&gt;&lt;br&gt;A&lt;sub&gt;class&lt;/sub&gt;=H(p&lt;sub&gt;final&lt;/sub&gt;) · A&lt;sub&gt;region&lt;/sub&gt;=JSD&lt;sub&gt;q&lt;/sub&gt;(p&lt;sub&gt;upper&lt;/sub&gt;,p&lt;sub&gt;middle&lt;/sub&gt;,p&lt;sub&gt;lower&lt;/sub&gt;) · U&lt;sub&gt;ext&lt;/sub&gt;=K/S(x).&lt;br&gt;&lt;b&gt;region_disagreement_valid=false&lt;/b&gt; khi tổng region quality không đủ.&lt;br&gt;Reliability head nhận global visual, mean/min quality, valid-region ratio, pose/crop quality; không nhận A&lt;sub&gt;region&lt;/sub&gt; hay raw region logits ở v1.&lt;br&gt;&lt;br&gt;L&lt;sub&gt;2&lt;/sub&gt;=CE&lt;sub&gt;final&lt;/sub&gt;+βL&lt;sub&gt;align&lt;/sub&gt;+λ&lt;sub&gt;rel&lt;/sub&gt;L&lt;sub&gt;reliability&lt;/sub&gt;+λ&lt;sub&gt;inside&lt;/sub&gt;L&lt;sub&gt;routing&lt;/sub&gt;. Không tối ưu trực tiếp A&lt;sub&gt;region&lt;/sub&gt;." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1215" y="1500" width="1120" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="outputs_test" value="&lt;b&gt;Claim ambiguity chỉ khi&lt;/b&gt;&lt;br&gt;• A&lt;sub&gt;region&lt;/sub&gt; tương quan human label disagreement&lt;br&gt;• corruption chủ yếu tăng U&lt;sub&gt;ext&lt;/sub&gt;, không tăng giả A&lt;sub&gt;region&lt;/sub&gt;&lt;br&gt;• NLL/Brier/E-AURC và error/OOD AUROC cải thiện&lt;br&gt;• common-logit offset invariant&lt;br&gt;&lt;br&gt;FERPlus kiểm tra annotator entropy.&lt;br&gt;&lt;font color=&quot;#6D28D9&quot;&gt;&lt;b&gt;Đối chiếu [R8–R11]&lt;/b&gt;&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.7;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=left;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="2410" y="1500" width="720" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="outputs_delta" value="SỬA" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.8;endArrow=block;endFill=1;fontFamily=Arial;fontSize=19;fontColor=#111827;labelBackgroundColor=#FFFFFF;" parent="1" source="outputs_before" target="outputs_after" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="outputs_evidence" value="KIỂM CHỨNG" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00827C;strokeWidth=2.8;endArrow=block;endFill=1;fontFamily=Arial;fontSize=19;fontColor=#111827;labelBackgroundColor=#FFFFFF;" parent="1" source="outputs_after" target="outputs_test" edge="1">
