<mxfile host="app.diagrams.net" modified="2026-07-03T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="emotionclip_reid_w4_two_stage_training" name="W4 Two-Stage Training">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1320" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="&lt;b&gt;Two-Stage Training Protocol - Input / Process / Output&lt;/b&gt;&lt;br&gt;Coarse overview for reporting; detailed uncertainty is separated in Figure 2b." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#FFFFFF;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=20;" vertex="1" parent="1"><mxGeometry x="70" y="30" width="1020" height="90" as="geometry"/></mxCell><mxCell id="legend_input" value="&lt;b&gt;INPUT&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1370" y="50" width="145" height="40" as="geometry"/></mxCell><mxCell id="legend_process" value="&lt;b&gt;PROCESS&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1540" y="50" width="165" height="40" as="geometry"/></mxCell><mxCell id="legend_output" value="&lt;b&gt;OUTPUT&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1735" y="50" width="155" height="40" as="geometry"/></mxCell><mxCell id="legend_unc" value="&lt;b&gt;UNCERTAINTY TERM&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1920" y="50" width="230" height="40" as="geometry"/></mxCell><mxCell id="stage1" value="&lt;b&gt;Stage 1 - Descriptor Learning&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F8FBFF;strokeColor=#2563EB;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=20;" vertex="1" parent="1"><mxGeometry x="70" y="165" width="2260" height="70" as="geometry"/></mxCell><mxCell id="s1_input" value="&lt;b&gt;INPUT&lt;/b&gt;&lt;br&gt;MODIFIED&lt;br&gt;Train images x&lt;br&gt;Emotion labels y&lt;br&gt;7 class names" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=16;" vertex="1" parent="1"><mxGeometry x="125" y="275" width="410" height="170" as="geometry"/></mxCell><mxCell id="s1_process" value="&lt;b&gt;Descriptor learning block&lt;/b&gt;&lt;br&gt;NEW W4&lt;br&gt;Frozen CLIP image/text encoders.&lt;br&gt;Train only class-specific prompt tokens.&lt;br&gt;Loss: CE(logit_scale * z_v T^T, y)." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=16;" vertex="1" parent="1"><mxGeometry x="675" y="245" width="640" height="230" as="geometry"/></mxCell><mxCell id="s1_output" value="&lt;b&gt;OUTPUT&lt;/b&gt;&lt;br&gt;NEW W4&lt;br&gt;Fixed emotion descriptors T&lt;br&gt;Descriptor checkpoint&lt;br&gt;Semantic anchors for Stage 2" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1500" y="275" width="500" height="170" as="geometry"/></mxCell><mxCell id="stage2" value="&lt;b&gt;Stage 2 - EmotionCLIP-ReID Fine-tuning&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFF8FC;strokeColor=#DB2777;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=20;" vertex="1" parent="1"><mxGeometry x="70" y="635" width="2260" height="70" as="geometry"/></mxCell><mxCell id="s2_input" value="&lt;b&gt;INPUT&lt;/b&gt;&lt;br&gt;MODIFIED&lt;br&gt;Train/val images x&lt;br&gt;Emotion labels y&lt;br&gt;Fixed descriptors T from Stage 1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=16;" vertex="1" parent="1"><mxGeometry x="125" y="760" width="430" height="185" as="geometry"/></mxCell><mxCell id="s2_model" value="&lt;b&gt;EmotionCLIP-ReID model block&lt;/b&gt;&lt;br&gt;NEW W4&lt;br&gt;CLIP ViT + expression adapters.&lt;br&gt;Classifier logits + global alignment + local Top-K alignment.&lt;br&gt;Fusion logits: s = w_cls s_cls + w_g s_g + w_l s_l." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=16;" vertex="1" parent="1"><mxGeometry x="670" y="720" width="585" height="265" as="geometry"/></mxCell><mxCell id="s2_loss" value="&lt;b&gt;Training objective block&lt;/b&gt;&lt;br&gt;MODIFIED&lt;br&gt;L_total = L_cls + beta L_align + lambda_unc L_unc.&lt;br&gt;Uncertainty is one calibration term here; detail is shown in Figure 2b." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1370" y="720" width="450" height="265" as="geometry"/></mxCell><mxCell id="s2_output" value="&lt;b&gt;OUTPUT / EVIDENCE&lt;/b&gt;&lt;br&gt;NEW W4&lt;br&gt;best_emotionclip.pth&lt;br&gt;Prediction probabilities&lt;br&gt;Uncertainty score&lt;br&gt;Metrics: macro-F1, balanced acc, ECE, risk AUC" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1910" y="720" width="380" height="265" as="geometry"/></mxCell><mxCell id="note" value="&lt;b&gt;Ghi chú&lt;/b&gt;&lt;br&gt;Sơ đồ này cố ý không tách nhỏ uncertainty; chỉ giữ vai trò là thành phần loss/calibration. Chi tiết công thức nằm ở sơ đồ uncertainty riêng." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2.4;fontFamily=Arial;fontColor=#111827;spacing=14;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1"><mxGeometry x="170" y="1190" width="1840" height="92" as="geometry"/></mxCell><mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2.6;endArrow=block;endFill=1;fontSize=14;fontFamily=Arial;fontColor=#2563EB;" edge="1" parent="1" source="s1_input" target="s1_process"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="learned descriptors" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#16A34A;strokeWidth=2.6;endArrow=block;endFill=1;fontSize=14;fontFamily=Arial;fontColor=#16A34A;" edge="1" parent="1" source="s1_process" target="s1_output"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2.6;endArrow=block;endFill=1;fontSize=14;fontFamily=Arial;fontColor=#2563EB;" edge="1" parent="1" source="s2_input" target="s2_model"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#16A34A;strokeWidth=2.6;endArrow=block;endFill=1;fontSize=14;fontFamily=Arial;fontColor=#16A34A;" edge="1" parent="1" source="s2_model" target="s2_loss"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.6;endArrow=block;endFill=1;fontSize=14;fontFamily=Arial;fontColor=#DB2777;" edge="1" parent="1" source="s2_loss" target="s2_output"><mxGeometry relative="1" as="geometry"/></mxCell></root>
    </mxGraphModel>
  </diagram>
