    <diagram id="emotionclip-reid-current-system" name="Current Academic System">
        <mxGraphModel dx="1800" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3600" pageHeight="2140" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;b&gt;EmotionCLIP-ReID hiện tại: sơ đồ học thuật hệ thống phát triển từ baseline CLIP-ReID&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#0F2742;fontSize=39;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="32" width="3050" height="58" as="geometry"/></mxCell>
                <mxCell id="subtitle" value="Sơ đồ bám theo baseline fig/method.png: kế thừa dual-encoder CLIP, prompt learning/semantic anchoring hai giai đoạn của CLIP-ReID, và hiện thực FER trong codebase này." style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#475569;fontSize=21;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="75" y="92" width="3150" height="42" as="geometry"/></mxCell>
                <mxCell id="legend_0" value="&lt;b&gt;REUSE/FROZEN&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#2563EB;strokeColor=#2563EB;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=13;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2470" y="44" width="185" height="30" as="geometry"/></mxCell>
                <mxCell id="legend_1" value="&lt;b&gt;IMPLEMENTED&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#16A34A;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=13;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2676" y="44" width="185" height="30" as="geometry"/></mxCell>
                <mxCell id="legend_2" value="&lt;b&gt;TRAINABLE&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#D97706;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=13;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2882" y="44" width="185" height="30" as="geometry"/></mxCell>
                <mxCell id="legend_3" value="&lt;b&gt;LOSS/METRIC&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DB2777;strokeColor=#DB2777;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=13;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="3088" y="44" width="185" height="30" as="geometry"/></mxCell>
                <mxCell id="legend_4" value="&lt;b&gt;OPTIONAL&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#6D28D9;strokeColor=#6D28D9;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=13;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="3294" y="44" width="185" height="30" as="geometry"/></mxCell>
                <mxCell id="baseline_panel" value="&lt;b&gt;Nền tảng kế thừa từ baseline&lt;/b&gt;&lt;br&gt;&lt;font style='font-size: 20px; color: #475569;'&gt;CLIP -&gt; CoOp prompt learning -&gt; CLIP-ReID two-stage semantic anchoring&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2563EB;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=29;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1"><mxGeometry x="70" y="160" width="3460" height="235" as="geometry"/></mxCell>
                <mxCell id="b_clip" value="&lt;b&gt;CLIP Cross-Modal Pretraining&lt;/b&gt;&lt;br&gt;dual encoder: image/text&lt;br&gt;shared embedding space" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="130" y="245" width="420" height="95" as="geometry"/></mxCell>
                <mxCell id="b_coop" value="&lt;b&gt;CoOp Prompt Learning&lt;/b&gt;&lt;br&gt;learnable prompt vectors&lt;br&gt;instead of manual prompt engineering" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="660" y="245" width="470" height="95" as="geometry"/></mxCell>
                <mxCell id="b_clipreid" value="&lt;b&gt;Semantic Anchoring&lt;/b&gt;&lt;br&gt;Stage 1 learns text tokens&lt;br&gt;Stage 2 fixes text anchors for visual tuning" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1240" y="235" width="540" height="115" as="geometry"/></mxCell>
                <mxCell id="b_mapping" value="&lt;b&gt;Current FER adaptation&lt;/b&gt;&lt;br&gt;ID-specific ambiguous descriptions -&gt; emotion semantic descriptors&lt;br&gt;person/vehicle ReID objective -&gt; facial expression recognition objective" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1900" y="226" width="830" height="132" as="geometry"/></mxCell>
                <mxCell id="b_guard" value="&lt;b&gt;Reality constraint&lt;/b&gt;&lt;br&gt;AU fields are parsed as metadata only; no AU fusion branch is trained in current implementation." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=18;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2850" y="235" width="560" height="115" as="geometry"/></mxCell>
                <mxCell id="e_b1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2.8;endArrow=block;endFill=1;fontSize=16;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b_clip" target="b_coop"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e_b2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D97706;strokeWidth=2.8;endArrow=block;endFill=1;fontSize=16;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b_coop" target="b_clipreid"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e_b3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#16A34A;strokeWidth=2.8;endArrow=block;endFill=1;fontSize=16;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="b_clipreid" target="b_mapping"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e_b4" value="scope check" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#B42318;strokeWidth=2.8;endArrow=block;endFill=1;fontSize=16;fontColor=#111827;labelBackgroundColor=#FFFFFF;dashed=1;dashPattern=8 8;" edge="1" parent="1" source="b_mapping" target="b_guard"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="data_panel" value="&lt;b&gt;A. FER Data &amp; Experimental Protocol&lt;/b&gt;&lt;br&gt;&lt;font style='font-size: 20px; color: #475569;'&gt;datasets/emotion_manifest.py + config/emotion_defaults.py&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#00827C;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=29;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1"><mxGeometry x="70" y="445" width="665" height="1225" as="geometry"/></mxCell>
                <mxCell id="d_manifest" value="&lt;b&gt;Emotion JSONL Manifest&lt;/b&gt;&lt;br&gt;image_path, emotion/emotion_id, split&lt;br&gt;optional AU labels/text retained" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="555" width="540" height="125" as="geometry"/></mxCell>
                <mxCell id="d_canon" value="&lt;b&gt;Canonical emotion ontology&lt;/b&gt;&lt;br&gt;7 classes: anger, disgust, fear,&lt;br&gt;happiness, sadness, surprise, neutral" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="730" width="540" height="118" as="geometry"/></mxCell>
                <mxCell id="d_transform" value="&lt;b&gt;Face-Safe Visual Transformation&lt;/b&gt;&lt;br&gt;RGB conversion, ImageOps.fit(224x224),&lt;br&gt;mild flip/color jitter, CLIP normalization" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="900" width="540" height="138" as="geometry"/></mxCell>
                <mxCell id="d_loaders" value="&lt;b&gt;Stage-Aware Data Path&lt;/b&gt;&lt;br&gt;Stage 1 path: precomputed image features&lt;br&gt;Stage 2 loader: train images&lt;br&gt;Validation loader feeds FER evaluation" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="1092" width="540" height="150" as="geometry"/></mxCell>
                <mxCell id="d_leakage" value="&lt;b&gt;Split-Leakage Guard&lt;/b&gt;&lt;br&gt;video_id/subject_id leakage check&lt;br&gt;strict by default" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="125" y="1295" width="540" height="112" as="geometry"/></mxCell>
                <mxCell id="d_au" value="&lt;b&gt;AU metadata prior&lt;/b&gt;&lt;br&gt;au_labels + au_text are preserved&lt;br&gt;but not consumed by the model yet" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#6D28D9;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;dashed=1;dashPattern=8 8;" vertex="1" parent="1"><mxGeometry x="125" y="1450" width="540" height="112" as="geometry"/></mxCell>
                <mxCell id="s1_panel" value="&lt;b&gt;B. Stage 1 - Semantic Descriptor Learning&lt;/b&gt;&lt;br&gt;&lt;font style='font-size: 20px; color: #475569;'&gt;processor.do_train_emotion_stage1 + model.EmotionPromptLearner&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2563EB;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=29;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1"><mxGeometry x="780" y="445" width="1215" height="1225" as="geometry"/></mxCell>
                <mxCell id="s1_img" value="&lt;b&gt;Frozen CLIP Visual Encoder&lt;/b&gt;&lt;br&gt;precompute z_v = f_img(x)&lt;br&gt;no gradient update" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="835" y="565" width="345" height="125" as="geometry"/></mxCell>
                <mxCell id="s1_prompt" value="&lt;b&gt;Emotion Prompt Learner&lt;/b&gt;&lt;br&gt;A photo of a face showing [X]...&lt;br&gt;expression of {emotion}&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;ctx vectors are the only trainable block in Stage 1&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="835" y="790" width="475" height="150" as="geometry"/></mxCell>
                <mxCell id="s1_text" value="&lt;b&gt;Frozen CLIP Text Encoder&lt;/b&gt;&lt;br&gt;Transformer text tower + projection&lt;br&gt;produces candidate descriptors T" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1420" y="800" width="430" height="132" as="geometry"/></mxCell>
                <mxCell id="s1_logits" value="&lt;b&gt;Image-Text Similarity Classifier&lt;/b&gt;&lt;br&gt;S_1 = exp(τ) · z_v T^T" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=21;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1100" y="1060" width="420" height="105" as="geometry"/></mxCell>
                <mxCell id="s1_loss" value="&lt;b&gt;Stage-1 Optimization Objective&lt;/b&gt;&lt;br&gt;L_S1 = CrossEntropy(S_1, y)&lt;br&gt;optimizer: AdamW over prompt parameters" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="850" y="1270" width="560" height="132" as="geometry"/></mxCell>
                <mxCell id="s1_ckpt" value="&lt;b&gt;Stage-1 Prompt Checkpoint&lt;/b&gt;&lt;br&gt;stores learned prompt state&lt;br&gt;T = {z_t^c} is recomputed by get_text()" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1480" y="1250" width="410" height="155" as="geometry"/></mxCell>
                <mxCell id="s1_note" value="&lt;b&gt;Academic interpretation&lt;/b&gt;&lt;br&gt;Stage 1 replaces CLIP-ReID ID-token anchoring with emotion-class semantic anchoring." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="850" y="1480" width="980" height="82" as="geometry"/></mxCell>
                <mxCell id="s2_panel" value="&lt;b&gt;C. Stage 2 - Expression-Aware Visual Adaptation &amp; Calibration&lt;/b&gt;&lt;br&gt;&lt;font style='font-size: 20px; color: #475569;'&gt;model.EmotionCLIPModel + loss.emotion_stage2_loss + utils.fer_metrics&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#16A34A;strokeWidth=3.2;fontFamily=Arial;fontColor=#0F2742;fontSize=29;spacing=18;align=left;verticalAlign=top;container=1;pointerEvents=0;" vertex="1" parent="1"><mxGeometry x="2040" y="445" width="1490" height="1225" as="geometry"/></mxCell>
                <mxCell id="s2_input" value="&lt;b&gt;FER train batch&lt;/b&gt;&lt;br&gt;face image x + label y" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2100" y="555" width="260" height="105" as="geometry"/></mxCell>
                <mxCell id="s2_encoder" value="&lt;b&gt;Expression-Aware CLIP ViT-B/16&lt;/b&gt;&lt;br&gt;adapter after residual MLP blocks&lt;br&gt;train adapters + selected last blocks&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;adapter_dim=64; train_last_blocks=2 by default&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2430" y="530" width="470" height="155" as="geometry"/></mxCell>
                <mxCell id="s2_tokens" value="&lt;b&gt;Global/Local Visual Tokens&lt;/b&gt;&lt;br&gt;global token z_g&lt;br&gt;patch tokens P = {p_i}" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2980" y="555" width="405" height="120" as="geometry"/></mxCell>
                <mxCell id="s2_fixedt" value="&lt;b&gt;Fixed Semantic Anchors from Stage 1&lt;/b&gt;&lt;br&gt;T is recomputed then detached per epoch&lt;br&gt;text side is not optimized in Stage 2" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2110" y="790" width="415" height="130" as="geometry"/></mxCell>
                <mxCell id="s2_cls" value="&lt;b&gt;Parametric FER Classifier&lt;/b&gt;&lt;br&gt;S_cls = W z_g" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2595" y="805" width="275" height="92" as="geometry"/></mxCell>
                <mxCell id="s2_global" value="&lt;b&gt;Global Alignment&lt;/b&gt;&lt;br&gt;S_g = exp(τ) · z_g T^T" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2950" y="770" width="360" height="105" as="geometry"/></mxCell>
                <mxCell id="s2_local" value="&lt;b&gt;Local Patch-Text Alignment&lt;/b&gt;&lt;br&gt;S_l = exp(τ) · mean TopK(P T^T)&lt;br&gt;top-k salient facial patches" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2950" y="935" width="360" height="132" as="geometry"/></mxCell>
                <mxCell id="s2_fusion" value="&lt;b&gt;Learnable Logit Fusion&lt;/b&gt;&lt;br&gt;S = w_cls S_cls + w_g S_g + w_l S_l" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2570" y="1010" width="330" height="120" as="geometry"/></mxCell>
                <mxCell id="s2_evidence" value="&lt;b&gt;Evidential Calibration Head&lt;/b&gt;&lt;br&gt;e=softplus(S), α=e+1&lt;br&gt;p_c=α_c/Σα, u=K/Σα" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="3020" y="1195" width="330" height="135" as="geometry"/></mxCell>
                <mxCell id="s2_loss" value="&lt;b&gt;Joint Stage-2 Objective&lt;/b&gt;&lt;br&gt;L = CE(S,y) + β CE(S_g+S_l,y) + λ L_EDL&lt;br&gt;EDL annealing controls uncertainty regularization" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2130" y="1200" width="705" height="145" as="geometry"/></mxCell>
                <mxCell id="s2_metrics" value="&lt;b&gt;FER Evaluation &amp; Model Selection&lt;/b&gt;&lt;br&gt;accuracy, balanced accuracy, macro-F1,&lt;br&gt;per-class F1, confusion matrix, ECE,&lt;br&gt;uncertainty-risk AUC" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2.8;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=14;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2300" y="1450" width="800" height="142" as="geometry"/></mxCell>
                <mxCell id="e_d1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00827C;strokeWidth=2.8;endArrow=block;endFill=1;fontSize=16;fontColor=#111827;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="d_manifest" target="d_canon"><mxGeometry relative="1" as="geometry"/></mxCell>
