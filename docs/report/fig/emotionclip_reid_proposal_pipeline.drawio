                <mxCell id="s1_output" value="&lt;b&gt;Đầu ra Stage 1&lt;/b&gt;&lt;br&gt;Prompt checkpoint + candidate descriptors T&lt;br&gt;cố định để kiểm chứng ở Stage 2" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1000" y="1135" width="430" height="135" as="geometry"/></mxCell>
                <mxCell id="s1_output_tag" value="&lt;b&gt;TEST&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#D97706;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1312" y="1151" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s1_goal" value="&lt;b&gt;Mục tiêu và phản biện Stage 1&lt;/b&gt;&lt;br&gt;Thay ID-specific tokens bằng emotion-specific descriptors. Không được tự tuyên bố descriptors có ngữ nghĩa; phải chứng minh bằng ablation, retrieval/UMAP và confusion/per-class F1." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="115" y="1265" width="1315" height="125" as="geometry"/></mxCell>
