                <mxCell id="s2_fixed_t" value="&lt;b&gt;Fixed candidate T&lt;/b&gt;&lt;br&gt;T từ Stage 1&lt;br&gt;không cập nhật gradient&lt;br&gt;&lt;b&gt;kiểm chứng vai trò anchor&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1690" y="995" width="330" height="170" as="geometry"/></mxCell>
