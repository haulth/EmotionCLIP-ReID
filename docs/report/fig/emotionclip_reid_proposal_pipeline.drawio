                <mxCell id="s2_encoder" value="&lt;b&gt;Image Encoder tinh chỉnh&lt;/b&gt;&lt;br&gt;CLIP ViT + ExpressionAdapter trong các transformer blocks&lt;br&gt;train adapters + selected last blocks; freeze phần còn lại&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;ExpressionAdapter; train_last_blocks&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2240" y="310" width="430" height="225" as="geometry"/></mxCell>
