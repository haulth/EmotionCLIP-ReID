<mxfile host="app.diagrams.net" agent="Codex" version="24.7.17">
    <diagram id="emotionclip-reid-scientific-pipeline" name="Scientific Pipeline">
        <mxGraphModel dx="1800" dy="1050" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="1850" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;b&gt;EmotionCLIP-ReID: Sơ đồ phương pháp và giả thuyết kiểm chứng&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#10243E;fontSize=50;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="35" width="2450" height="70" as="geometry"/></mxCell>
                <mxCell id="subtitle" value="Từ CLIP-ReID baseline sang FER: Stage 1 học candidate emotion descriptors; Stage 2 kiểm tra liệu descriptors cố định có kéo visual features về vùng ngữ nghĩa cảm xúc hay không." style="text;whiteSpace=wrap;html=1;strokeColor=none;fillColor=none;fontFamily=Arial;fontColor=#475569;fontSize=25;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="75" y="105" width="2550" height="50" as="geometry"/></mxCell>
                <mxCell id="thesis_guard" value="&lt;b&gt;Luận điểm cần bảo vệ:&lt;/b&gt; đây là một chuyển đổi có kiểm soát từ ID-token anchoring sang emotion-descriptor anchoring; mỗi claim phải đi kèm ablation/metric, không chỉ dựa vào sơ đồ kiến trúc." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#CBD5E1;strokeWidth=1.5;fontFamily=Arial;fontColor=#111827;fontSize=18;spacing=4;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="75" y="155" width="2440" height="34" as="geometry"/></mxCell>
                <mxCell id="legend_0" value="&lt;b&gt;REUSE/FROZEN&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#2563EB;strokeColor=#2563EB;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=15;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2480" y="55" width="120" height="30" as="geometry"/></mxCell>
                <mxCell id="legend_1" value="&lt;b&gt;MODIFIED&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#D97706;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=15;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2615" y="55" width="120" height="30" as="geometry"/></mxCell>
                <mxCell id="legend_2" value="&lt;b&gt;NEW&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#16A34A;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=15;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2750" y="55" width="120" height="30" as="geometry"/></mxCell>
                <mxCell id="legend_3" value="&lt;b&gt;METRIC&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DB2777;strokeColor=#DB2777;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=15;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2885" y="55" width="120" height="30" as="geometry"/></mxCell>
                <mxCell id="legend_4" value="&lt;b&gt;OPTIONAL&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#6D28D9;strokeColor=#6D28D9;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=15;spacing=2;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="3020" y="55" width="120" height="30" as="geometry"/></mxCell>
                <mxCell id="stage1_panel" value="" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2563EB;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=24;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="190" width="1500" height="1260" as="geometry"/></mxCell>
                <mxCell id="stage2_panel" value="" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#00827C;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=24;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1640" y="190" width="1500" height="1260" as="geometry"/></mxCell>
                <mxCell id="divider" value="" style="endArrow=none;html=1;rounded=0;strokeColor=#111827;strokeWidth=3;" edge="1" parent="1"><mxGeometry width="50" height="50" relative="1" as="geometry"><mxPoint x="1600" y="210" as="sourcePoint"/><mxPoint x="1600" y="1440" as="targetPoint"/></mxGeometry></mxCell>
                <mxCell id="stage1_header" value="&lt;b&gt;Giai đoạn 1: Học Token/Descriptor Cảm xúc&lt;/b&gt;&lt;br&gt;&lt;font style='font-size: 26px;'&gt;(Emotion-based Token / Descriptor Learning)&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FFFFFF;strokeWidth=0;fontFamily=Arial;fontColor=#111827;fontSize=34;spacing=4;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="160" y="215" width="1280" height="92" as="geometry"/></mxCell>
                <mxCell id="stage2_header" value="&lt;b&gt;Giai đoạn 2: Tinh chỉnh với Adapter và Semantic Anchors&lt;/b&gt;&lt;br&gt;&lt;font style='font-size: 26px;'&gt;(Adapter-based Fine-tuning + Evidential Calibration)&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FFFFFF;strokeWidth=0;fontFamily=Arial;fontColor=#111827;fontSize=34;spacing=4;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1710" y="215" width="1340" height="92" as="geometry"/></mxCell>
                <mxCell id="s1_images" value="&lt;b&gt;Batch ảnh mặt&lt;/b&gt;&lt;br&gt;x, y từ FER manifest&lt;br&gt;RAF-DB / FER2013&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;EmotionManifestDataset&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=21;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="115" y="385" width="215" height="125" as="geometry"/></mxCell>
                <mxCell id="s1_images_tag" value="&lt;b&gt;MOD&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#D97706;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="212" y="401" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s1_image_encoder" value="&lt;b&gt;CLIP Image Encoder&lt;/b&gt;&lt;br&gt;ViT-B/16&lt;br&gt;&lt;b&gt;cố định&lt;/b&gt;&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;frozen visual encoder&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=24;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="390" y="330" width="310" height="210" as="geometry"/></mxCell>
                <mxCell id="s1_image_encoder_tag" value="&lt;b&gt;REUSE&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#2563EB;strokeColor=#2563EB;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="582" y="346" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s1_image_feat" value="&lt;b&gt;Image features&lt;/b&gt;&lt;br&gt;z_v = f_img(x)" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=23;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="770" y="380" width="230" height="110" as="geometry"/></mxCell>
                <mxCell id="s1_emotion_label" value="&lt;b&gt;Nhãn cảm xúc&lt;/b&gt;&lt;br&gt;7 lớp: anger, disgust,&lt;br&gt;fear, happiness, sadness,&lt;br&gt;surprise, neutral" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=21;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="115" y="760" width="270" height="155" as="geometry"/></mxCell>
                <mxCell id="s1_emotion_label_tag" value="&lt;b&gt;MOD&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#D97706;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="267" y="776" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s1_mer_prior" value="&lt;b&gt;AU/MER-CLIP prior&lt;/b&gt;&lt;br&gt;Không phải lõi v1. Chỉ thêm khi có AU label hoặc pseudo-AU đã kiểm định; dùng cho ablation riêng." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#6D28D9;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="115" y="985" width="350" height="130" as="geometry"/></mxCell>
                <mxCell id="s1_mer_prior_tag" value="&lt;b&gt;OPT&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#6D28D9;strokeColor=#6D28D9;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="347" y="1001" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s1_prompt" value="&lt;b&gt;Emotion Prompt Learner&lt;/b&gt;&lt;br&gt;Template cảm xúc + [X]...[X]&lt;br&gt;&lt;b&gt;class-specific learnable context tokens&lt;/b&gt;&lt;br&gt;không giả định AU luôn có sẵn&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;EmotionPromptLearner.ctx&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="480" y="705" width="520" height="210" as="geometry"/></mxCell>
                <mxCell id="s1_prompt_tag" value="&lt;b&gt;NEW&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#16A34A;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="882" y="721" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s1_text_encoder" value="&lt;b&gt;CLIP Text Encoder&lt;/b&gt;&lt;br&gt;Transformer + text projection&lt;br&gt;&lt;b&gt;cố định&lt;/b&gt;&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;EmotionTextEncoder&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=23;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1060" y="705" width="280" height="175" as="geometry"/></mxCell>
                <mxCell id="s1_text_encoder_tag" value="&lt;b&gt;REUSE&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#2563EB;strokeColor=#2563EB;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1222" y="721" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s1_text_feat" value="&lt;b&gt;Candidate descriptors&lt;/b&gt;&lt;br&gt;T = {z_t^c}&lt;br&gt;ứng viên anchor cho từng cảm xúc" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1180" y="930" width="300" height="120" as="geometry"/></mxCell>
                <mxCell id="s1_text_feat_tag" value="&lt;b&gt;NEW&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#16A34A;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1362" y="946" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s1_loss" value="&lt;b&gt;Stage 1 alignment loss&lt;/b&gt;&lt;br&gt;L_s1 = CE(logit_scale · z_v T^T, y)&lt;br&gt;chỉ cập nhật prompt tokens&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;processor_emotionclip.do_train_emotion_stage1&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="710" y="545" width="500" height="145" as="geometry"/></mxCell>
