                <mxCell id="s2_visual_feat" value="&lt;b&gt;Visual features&lt;/b&gt;&lt;br&gt;global z_g + patch tokens P" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2735" y="365" width="310" height="130" as="geometry"/></mxCell>
