                <mxCell id="s2_metrics" value="&lt;b&gt;Đầu ra &amp; protocol đánh giá&lt;/b&gt;&lt;br&gt;prediction, confidence, uncertainty&lt;br&gt;accuracy, macro-F1, balanced accuracy,&lt;br&gt;per-class F1, ECE, uncertainty-risk AUC&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;utils.fer_metrics.compute_fer_metrics&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=21;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2055" y="1240" width="710" height="135" as="geometry"/></mxCell>
