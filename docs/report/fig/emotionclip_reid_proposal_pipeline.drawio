                <mxCell id="stage1" value="&lt;font style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;Stage 1: học descriptor&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font&gt;Freeze image/text encoder. Tối ưu prompt tokens để tạo &lt;b&gt;z_t&lt;/b&gt; có khả năng phân biệt emotion và giữ ý nghĩa ngôn ngữ.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font&gt;&lt;b&gt;L_S1 = SupCon(z_v, z_t)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=18;align=center;verticalAlign=middle;fontSize=19;" parent="1" vertex="1">
