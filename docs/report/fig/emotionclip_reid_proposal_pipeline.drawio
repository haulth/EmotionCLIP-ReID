                <mxCell id="s2_goal" value="&lt;b&gt;Mục tiêu và phản biện Stage 2&lt;/b&gt;&lt;br&gt;Claim đúng chỉ khi fixed T + adapter + global/local + uncertainty vượt các ablation tương ứng; nếu không, sơ đồ chỉ là thêm module chứ chưa phải đóng góp khoa học." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1700" y="1385" width="1345" height="60" as="geometry"/></mxCell>
