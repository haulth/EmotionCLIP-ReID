                <mxCell id="s2_classifier" value="&lt;b&gt;Classifier logits&lt;/b&gt;&lt;br&gt;s_cls = W z_g" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#475569;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2100" y="650" width="285" height="110" as="geometry"/></mxCell>
                <mxCell id="s2_classifier_tag" value="&lt;b&gt;MOD&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#D97706;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2267" y="666" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s2_global" value="&lt;b&gt;Global alignment&lt;/b&gt;&lt;br&gt;s_g = τ · z_g T^T" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2440" y="610" width="295" height="115" as="geometry"/></mxCell>
                <mxCell id="s2_global_tag" value="&lt;b&gt;NEW&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#16A34A;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2617" y="626" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s2_local" value="&lt;b&gt;Local Top-K alignment&lt;/b&gt;&lt;br&gt;s_l = τ · mean TopK(P T^T)&lt;br&gt;giữ tín hiệu vùng cơ mặt nhỏ&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;local_alignment_logits&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=21;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2440" y="770" width="295" height="145" as="geometry"/></mxCell>
                <mxCell id="s2_local_tag" value="&lt;b&gt;NEW&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#16A34A;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2617" y="786" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s2_fusion" value="&lt;b&gt;Fusion logits&lt;/b&gt;&lt;br&gt;s = w_cls s_cls + w_g s_g + w_l s_l&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;learnable fusion_weights&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=22;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2805" y="650" width="275" height="160" as="geometry"/></mxCell>
                <mxCell id="s2_fusion_tag" value="&lt;b&gt;MOD&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#D97706;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2962" y="666" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s2_evidence" value="&lt;b&gt;Evidential output&lt;/b&gt;&lt;br&gt;e = softplus(s)&lt;br&gt;α = e + 1&lt;br&gt;p_c = α_c / Σα&lt;br&gt;u(x) = K / Σα" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=21;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2805" y="900" width="275" height="210" as="geometry"/></mxCell>
                <mxCell id="s2_evidence_tag" value="&lt;b&gt;NEW&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#16A34A;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2962" y="916" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s2_loss" value="&lt;b&gt;Hàm mất mát Stage 2&lt;/b&gt;&lt;br&gt;L_total = L_cls + β L_align + λ L_unc&lt;br&gt;L_cls = CE(s, y); L_align = CE(s_g + s_l, y)&lt;br&gt;L_unc = Dirichlet NLL + annealed KL&lt;br&gt;&lt;font style='font-size: 15px; color: #64748B;'&gt;emotion_stage2_loss&lt;/font&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=21;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2075" y="960" width="555" height="210" as="geometry"/></mxCell>
                <mxCell id="s2_loss_tag" value="&lt;b&gt;MOD&lt;/b&gt;" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#D97706;strokeWidth=1;fontFamily=Arial;fontColor=#FFFFFF;fontSize=17;spacing=3;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2512" y="976" width="96" height="30" as="geometry"/></mxCell>
                <mxCell id="s2_uafer" value="&lt;b&gt;Calibration hypothesis&lt;/b&gt;&lt;br&gt;u(x) là tín hiệu độ tin cậy, không phải bằng chứng robustness. Chỉ giữ claim nếu ECE/risk AUC tốt hơn ablation." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=19;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="2675" y="1160" width="385" height="115" as="geometry"/></mxCell>
