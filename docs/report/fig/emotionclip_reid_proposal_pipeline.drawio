                <mxCell id="modified_summary" value="&lt;b&gt;Claim đóng góp chính&lt;/b&gt;&lt;br&gt;ReID ID objective -&gt; 7-class FER; ID tokens -&gt; emotion descriptors; fixed T kiểm chứng như semantic anchors." style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=20;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="745" y="1590" width="650" height="155" as="geometry"/></mxCell>
