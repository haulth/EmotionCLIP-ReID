                </mxCell>
                <mxCell id="stage2" value="&lt;font style=&quot;color: rgb(0, 107, 102);&quot;&gt;&lt;b&gt;Stage 2: semantic anchor&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font&gt;Freeze descriptors. Fine-tune adapter/head để kéo visual embedding về đúng vùng semantic descriptor.&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font&gt;&lt;b&gt;L = L_cls + beta L_i2t + lambda L_unc&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2.2;fontFamily=Arial;fontColor=#111827;spacing=18;align=center;verticalAlign=middle;fontSize=19;" parent="1" vertex="1">
