                <mxCell id="s2_images" value="&lt;b&gt;Batch ảnh mặt&lt;/b&gt;&lt;br&gt;train/val images&lt;br&gt;+ labels y" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#475569;strokeWidth=3;fontFamily=Arial;fontColor=#111827;fontSize=21;spacing=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1690" y="385" width="210" height="125" as="geometry"/></mxCell>
