                <mxCell id="s2_reliability" value="&lt;b&gt;Decoupled strength head&lt;/b&gt;&lt;br&gt;stopgrad(g) + q&lt;sub&gt;1:3&lt;/sub&gt; + min/mean(q)&lt;br&gt;+ valid-region ratio + pose/crop quality&lt;br&gt;S = C + softplus(r)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF2F8;strokeColor=#DB2777;strokeWidth=2;arcSize=6;fontSize=14;fontColor=#831843;fontFamily=Helvetica;" parent="1" vertex="1">
