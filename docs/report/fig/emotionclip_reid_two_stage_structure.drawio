                <mxCell id="s2_fusion" value="&lt;b&gt;Per-branch temperature scaling&lt;br&gt;+ fixed simplex fusion&lt;/b&gt;&lt;br&gt;z&lt;sub&gt;fuse&lt;/sub&gt; = Σ&lt;sub&gt;b&lt;/sub&gt; w&lt;sub&gt;b&lt;/sub&gt;(ℓ&lt;sub&gt;b&lt;/sub&gt;/τ&lt;sub&gt;b&lt;/sub&gt;)&lt;br&gt;z&lt;sub&gt;align&lt;/sub&gt; = 0.5(ℓ&lt;sub&gt;g&lt;/sub&gt;/τ&lt;sub&gt;g&lt;/sub&gt; + ℓ&lt;sub&gt;l&lt;/sub&gt;/τ&lt;sub&gt;l&lt;/sub&gt;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#D97706;strokeWidth=2;arcSize=6;fontSize=14;fontColor=#7C2D12;fontFamily=Helvetica;" parent="1" vertex="1">
