                </mxCell>
                <mxCell id="s1_face" value="face&lt;br&gt;image x" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2;arcSize=8;fontSize=20;fontColor=#111827;fontFamily=Helvetica;" parent="1" vertex="1">
