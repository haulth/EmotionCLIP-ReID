                <mxCell id="intro" value="Phương án &lt;b&gt;EmotionCLIP-ReID&lt;/b&gt; đề xuất kế thừa khung huấn luyện 2 giai đoạn của CLIP-ReID&lt;br&gt;và chuyển trọng tâm từ định danh ID sang descriptor ngữ nghĩa cho nhận dạng cảm xúc bền bỉ." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontColor=#111827;fontFamily=Helvetica;" parent="1" vertex="1">
                    <mxGeometry x="45" y="25" width="1600" height="60" as="geometry"/>
