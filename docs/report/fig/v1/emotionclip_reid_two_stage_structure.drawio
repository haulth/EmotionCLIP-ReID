                </mxCell>
                <mxCell id="s1_prompt" value="&lt;b&gt;Learnable structured prompt&lt;/b&gt;&lt;br&gt;A photo of a person expressing &lt;font color=&quot;#CA8A04&quot;&gt;[Emotion c]&lt;/font&gt;,&lt;br&gt;characterized by &lt;font color=&quot;#CA8A04&quot;&gt;[X]&lt;sub&gt;1:M&lt;/sub&gt; / optional AU tokens&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0F3A5C;strokeColor=#0B2545;strokeWidth=2.2;arcSize=8;fontSize=20;fontColor=#FFFFFF;fontFamily=Helvetica;" parent="1" vertex="1">
