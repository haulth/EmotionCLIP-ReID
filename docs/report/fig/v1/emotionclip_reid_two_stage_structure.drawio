                <mxCell id="s1_text_encoder" value="🔒&lt;br&gt;&lt;b&gt;Text&lt;br&gt;Encoder&lt;/b&gt;&lt;br&gt;(Cố định)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;size=0.12;fillColor=#64748B;strokeColor=#334155;strokeWidth=2;fontSize=20;fontColor=#FFFFFF;fontFamily=Helvetica;direction=west;" parent="1" vertex="1">
