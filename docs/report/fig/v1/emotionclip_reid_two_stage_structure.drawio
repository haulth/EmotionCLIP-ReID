                <mxCell id="s1_contrastive" value="&lt;b&gt;Contrastive Loss&lt;/b&gt;&lt;br&gt;L&lt;sub&gt;S1&lt;/sub&gt; = SupCon(z&lt;sub&gt;v&lt;/sub&gt;, z&lt;sub&gt;t&lt;/sub&gt;)&lt;br&gt;align image ↔ emotion text" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F2937;strokeWidth=2;arcSize=8;fontSize=20;fontColor=#111827;fontFamily=Helvetica;" parent="1" vertex="1">
