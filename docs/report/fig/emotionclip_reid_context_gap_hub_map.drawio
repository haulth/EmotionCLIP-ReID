<mxfile host="app.diagrams.net" modified="2026-05-18T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="emotionclip-context-gap-hub-map" name="Context Gap Hub Map">
    <mxGraphModel dx="1440" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1420" pageHeight="860" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Bối cảnh nghiên cứu và research gap trung tâm&lt;br&gt;Các nhóm công trình hội tụ quanh một vấn đề FER in-the-wild, không phải chuỗi nối tiếp" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F8FAFC;strokeColor=#10243E;strokeWidth=2;fontSize=22;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="300" y="30" width="820" height="80" as="geometry"/></mxCell><mxCell id="clip" value="CLIP/VLM adaptation&lt;br&gt;Đóng góp: prompt/adapter learning&lt;br&gt;Hạn chế: prompt cấp lớp còn thô" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EAF2FF;strokeColor=#2563EB;strokeWidth=2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="170" width="320" height="125" as="geometry"/></mxCell><mxCell id="reid" value="ReID + language&lt;br&gt;Đóng góp: text anchor hai giai đoạn&lt;br&gt;Hạn chế: anchor chỉ định danh" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#ECFDF3;strokeColor=#15803D;strokeWidth=2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="370" width="320" height="125" as="geometry"/></mxCell><mxCell id="au" value="AU/FACS semantics&lt;br&gt;Đóng góp: tín hiệu cơ mặt diễn giải&lt;br&gt;Hạn chế: AU thiếu/noisy" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="570" width="320" height="125" as="geometry"/></mxCell><mxCell id="fer" value="CLIP-based FER/DFER&lt;br&gt;Đóng góp: text descriptors/adapters&lt;br&gt;Hạn chế: descriptor chưa thành anchor" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFF7E6;strokeColor=#C77D00;strokeWidth=2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1050" y="170" width="320" height="125" as="geometry"/></mxCell><mxCell id="unc" value="Uncertainty-aware FER&lt;br&gt;Đóng góp: ambiguity/overconfidence&lt;br&gt;Hạn chế: dễ làm loãng thesis" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFF1F2;strokeColor=#B42318;strokeWidth=2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1050" y="370" width="320" height="125" as="geometry"/></mxCell><mxCell id="mer" value="Multimodal MER&lt;br&gt;Đóng góp: reliability/fusion&lt;br&gt;Hạn chế: đổi bài toán, tốn dữ liệu" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F3E8FF;strokeColor=#6D28D9;strokeWidth=2;fontSize=14;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1050" y="570" width="320" height="125" as="geometry"/></mxCell><mxCell id="gap" value="Research gap trung tâm&lt;br&gt;FER in-the-wild thiếu cơ chế neo visual features vào tín hiệu emotion/AU có nghĩa, nên khó ổn định khi che khuất, lệch góc nhìn và domain shift.&lt;br&gt;CLIP-ReID là scaffold kỹ thuật, không phải research problem." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#B42318;strokeWidth=2;fontSize=16;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="505" y="300" width="430" height="230" as="geometry"/></mxCell><mxCell id="proposal" value="Đề xuất hiện tại&lt;br&gt;Dùng two-stage learning như scaffold.&lt;br&gt;Học emotion/AU descriptors rồi cố định chúng làm semantic anchors cho visual encoder.&lt;br&gt;AU/uncertainty là ablation có kiểm soát." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E8F7F4;strokeColor=#00827C;strokeWidth=2;fontSize=16;fontFamily=Arial;fontColor=#111827;spacing=14;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="500" y="650" width="440" height="170" as="geometry"/></mxCell><mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="clip" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#15803D;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="reid" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00827C;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="au" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C77D00;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="fer" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#B42318;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="unc" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6D28D9;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="mer" target="gap"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00827C;strokeWidth=2.5;endArrow=block;endFill=1;" edge="1" parent="1" source="gap" target="proposal"><mxGeometry relative=