  <diagram id="emotionclip_reid_w4_uncertainty_detail" name="emotionclip_reid_w4_uncertainty_detail">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2100" pageHeight="1180" math="0" shadow="0">
      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="&lt;b&gt;Evidential Uncertainty / Calibration Detail&lt;/b&gt;&lt;br&gt;logits -&gt; Dirichlet evidence -&gt; probability, uncertainty, ECE and risk AUC." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#FFFFFF;strokeWidth=2.2;fontSize=20;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="70" y="30" width="1050" height="80" as="geometry"/></mxCell><mxCell id="logits" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;Fused logits&lt;br&gt;s = w_cls s_cls + w_g s_g + w_l s_l" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="90" y="210" width="255" height="120" as="geometry"/></mxCell><mxCell id="evidence" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Evidence&lt;br&gt;e = softplus(s)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="430" y="210" width="255" height="120" as="geometry"/></mxCell><mxCell id="alpha" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Dirichlet alpha&lt;br&gt;alpha = e + 1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="770" y="210" width="255" height="120" as="geometry"/></mxCell><mxCell id="strength" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Strength&lt;br&gt;S = sum_c alpha_c" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1110" y="210" width="255" height="120" as="geometry"/></mxCell><mxCell id="prob" value="Probabilities&lt;br&gt;p_c = alpha_c / S&lt;br&gt;prediction + confidence" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1480" y="135" width="270" height="120" as="geometry"/></mxCell><mxCell id="uscore" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Uncertainty score&lt;br&gt;u(x) = K / S" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1480" y="315" width="270" height="120" as="geometry"/></mxCell><mxCell id="ece" value="METRIC&lt;br&gt;ECE&lt;br&gt;bin confidence vs. accuracy" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1820" y="125" width="230" height="140" as="geometry"/></mxCell><mxCell id="risk" value="METRIC&lt;br&gt;Uncertainty-risk AUC&lt;br&gt;sort by uncertainty, measure risk" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1820" y="310" width="230" height="140" as="geometry"/></mxCell><mxCell id="label" value="Label y + alpha&lt;br&gt;one-hot target + Dirichlet parameters" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#334155;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="160" y="575" width="315" height="150" as="geometry"/></mxCell><mxCell id="edl" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Evidential CE loss&lt;br&gt;NLL_Dirichlet + anneal * KL(alpha_tilde || Uniform)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FCE7F3;strokeColor=#DB2777;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="575" y="575" width="390" height="150" as="geometry"/></mxCell><mxCell id="total" value="&lt;b&gt;MODIFIED&lt;/b&gt;&lt;br&gt;Weighted objective&lt;br&gt;L_total = L_cls + beta_align L_align + lambda_unc L_unc" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1070" y="575" width="360" height="150" as="geometry"/></mxCell><mxCell id="logs" value="&lt;b&gt;NEW W4&lt;/b&gt;&lt;br&gt;Training logs&lt;br&gt;unc_loss, pred_unc, conf, avg_unc, avg_conf, ECE, risk AUC" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2.2;fontSize=15;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1535" y="575" width="410" height="150" as="geometry"/></mxCell><mxCell id="note" value="Cách diễn giải: uncertainty là bằng chứng calibration/robustness, không thay thế accuracy. ECE còn cao nên cần temperature scaling hoặc calibration-aware loss ở vòng sau." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2.2;fontSize=17;fontFamily=Arial;fontColor=#111827;spacing=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="180" y="865" width="1740" height="190" as="geometry"/></mxCell><mxCell id="edge_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="logits" target="evidence"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="evidence" target="alpha"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="alpha" target="strength"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="strength" target="prob"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="strength" target="uscore"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563EB;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="prob" target="ece"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="uscore" target="risk"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DB2777;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="alpha" target="edl"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="label" target="edl"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D97706;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="edl" target="total"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="edge_11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#16A34A;strokeWidth=2.4;endArrow=block;endFill=1;fontSize=14;" edge="1" parent="1" source="total" target="logs"><mxGeometry relative="1" as="geometry"/></mxCell></root>
